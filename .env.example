# ---------------------------------------------------------------------------
# Manibot — required environment variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.
# ---------------------------------------------------------------------------

# Groq API key — required for all AI chat responses
# Get one at: https://console.groq.com/keys
GROQ_API_KEY="gsk_..."

# Neon Postgres connection string — required for session + message persistence
# Get one at: https://neon.tech (free tier available)
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL="postgresql://..."

# Gate password — required for login page auth
# Set to any strong secret string
GATE_PASSWORD="your-password"
